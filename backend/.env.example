# PrestaShop Webservice Configuration
PRESTASHOP_URL=https://example.com/api/
PRESTASHOP_API_KEY=YOUR_PRESTASHOP_WEBSERVICE_KEY

# Set to True to use mock/simulated PrestaShop data instead of hitting real APIs
MOCK_MODE=True

# SQLite Database Location
DATABASE_URL=sqlite:///./inventory.db

# Default PrestaShop Order State IDs to include in calculations (comma-separated)
# e.g., if "magazzino rosate" is state ID 12
DEFAULT_STATE_IDS=12

# Token opzionale per la beta dell'estensione Chrome.
# Se valorizzato, l'estensione deve inviarlo nell'header X-Giac-Extension-Token.
GIAC_EXTENSION_TOKEN=
